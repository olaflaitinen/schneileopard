root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{scala,java}]
indent_style = space
indent_size = 2
max_line_length = 100

[*.{md,txt}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[{Makefile,.sbt,build.properties}]
indent_style = tab

[*.sbt]
indent_style = space
indent_size = 2
